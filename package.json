{
  "name": "refusalrail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port ${PORT:-4387} --local",
    "build": "tsc --noEmit && npm run contracts:compile",
    "contracts:compile": "node scripts/compile-contracts.mjs",
    "contracts:deploy": "node scripts/deploy-contracts.mjs",
    "seed": "node scripts/seed_demo.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "deploy:dry": "wrangler deploy --dry-run --outdir dist-worker",
    "deploy": "wrangler deploy --minify",
    "types:cf": "wrangler types ./src/worker-configuration.d.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@playwright/test": "latest",
    "@types/node": "^25.9.1",
    "ethers": "^6.16.0",
    "solc": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
